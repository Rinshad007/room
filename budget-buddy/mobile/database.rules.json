{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "expenses": {
      ".read": "auth != null",
      "$expenseId": {
        ".write": "auth != null && (newData.child('paid_by').val() === auth.uid || !data.exists())"
      }
    },
    "groups": {
      ".read": "auth != null",
      "$groupId": {
        ".write": "auth != null && (newData.child('created_by').val() === auth.uid || !data.exists() || data.child('created_by').val() === auth.uid)"
      }
    },
    "settlements": {
      ".read": "auth != null",
      "$settlementId": {
        ".write": "auth != null && (newData.child('payer_id').val() === auth.uid || !data.exists() || data.child('receiver_id').val() === auth.uid)"
      }
    },
    "friendships": {
      ".read": "auth != null",
      "$friendshipId": {
        ".write": "auth != null && (newData.child('sender_id').val() === auth.uid || !data.exists() || data.child('receiver_id').val() === auth.uid)"
      }
    },
    "notifications": {
      "$notifId": {
        ".read": "auth != null && data.child('user_id').val() === auth.uid",
        ".write": "auth != null"
      }
    },
    "budgets": {
      "$budgetId": {
        ".read": "auth != null && data.child('user_id').val() === auth.uid",
        ".write": "auth != null && newData.child('user_id').val() === auth.uid"
      }
    }
  }
}
